generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model agentes {
  id                                        String                @id
  usuario_id                                String                @unique
  tipo                                      TipoAgente
  clave                                     String                @unique
  activo                                    Boolean               @default(true)
  created_at                                DateTime              @default(now())
  usuarios                                  usuarios              @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  asignaciones_cuenta                       asignaciones_cuenta[]
  cola_trabajo                              cola_trabajo[]
  gestiones_gestiones_agente_idToagentes    gestiones[]           @relation("gestiones_agente_idToagentes")
  gestiones_gestiones_visitador_idToagentes gestiones[]           @relation("gestiones_visitador_idToagentes")

  @@index([tipo])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model asignaciones_cuenta {
  id               String   @id
  cuenta_id        String   @unique
  agente_id        String
  asignado_por     String?
  fecha_asignacion DateTime @default(now())
  activa           Boolean  @default(true)
  agentes          agentes  @relation(fields: [agente_id], references: [id])
  cuentas          cuentas  @relation(fields: [cuenta_id], references: [id])

  @@index([agente_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id            String    @id
  timestamp     DateTime  @default(now())
  usuario_id    String?
  usuario_email String?
  accion        String
  recurso_tipo  String
  recurso_id    String?
  tenant_id     String?
  ip_address    String?
  user_agent    String?
  old_values    Bytes?
  new_values    Bytes?
  exitoso       Boolean   @default(true)
  error_mensaje String?
  usuarios      usuarios? @relation(fields: [usuario_id], references: [id])

  @@index([recurso_tipo, recurso_id])
  @@index([tenant_id])
  @@index([timestamp])
  @@index([usuario_id])
}

